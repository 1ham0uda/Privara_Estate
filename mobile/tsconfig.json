{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/*.bak",
    "app.expo-router.bak",
    "components.template.bak",
    "hooks.template.bak",
    "constants.template.bak"
  ]
}
