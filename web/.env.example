NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Choose ONE Firebase Admin SDK option below for server routes like /api/admin/create-staff
# Option 1: Point to a downloaded service account JSON file on your machine
GOOGLE_APPLICATION_CREDENTIALS=

# Option 2: Inline the service account credentials in env vars
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# WebRTC / calling
# REQUIRED FOR PRODUCTION: without a TURN server, calls fail for ~20% of user pairs
# (symmetric NAT, mobile carriers, corporate firewalls). Providers: Twilio, Metered, Xirsys.
NEXT_PUBLIC_WEBRTC_TURN_URLS=turn:your-turn-host:3478
NEXT_PUBLIC_WEBRTC_TURN_USERNAME=your_turn_username
NEXT_PUBLIC_WEBRTC_TURN_CREDENTIAL=your_turn_password
# Advanced alternative — supply a full ICE server array as JSON (overrides the 3 vars above):
# NEXT_PUBLIC_WEBRTC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:your-turn-host:3478"],"username":"user","credential":"pass"}]

# Application URL used by server routes for payment callbacks/returns
APP_URL=https://privara-estate--privara-estate.us-east4.hosted.app
NEXT_PUBLIC_APP_URL=https://privara-estate--privara-estate.us-east4.hosted.app

# Geidea payment gateway
GEIDEA_PUBLIC_KEY=
GEIDEA_API_PASSWORD=
GEIDEA_SESSION_URL=https://api.merchant.geidea.net/payment-intent/api/v2/direct/session
GEIDEA_CALLBACK_URL=https://privara-estate--privara-estate.us-east4.hosted.app/api/payments/geidea/callback
GEIDEA_RETURN_URL=https://privara-estate--privara-estate.us-east4.hosted.app/client/payment
NEXT_PUBLIC_GEIDEA_CHECKOUT_SCRIPT_URL=https://www.merchant.geidea.net/hpp/geideaCheckout.min.js
