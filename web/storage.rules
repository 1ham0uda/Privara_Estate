rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isConsultationParticipant(caseId) {
      // firestore.get() throws on a missing document; guard with exists() first
      return firestore.exists(/databases/(default)/documents/consultations/$(caseId)) && (
        firestore.get(/databases/(default)/documents/consultations/$(caseId)).data.clientId == request.auth.uid ||
        firestore.get(/databases/(default)/documents/consultations/$(caseId)).data.consultantId == request.auth.uid ||
        firestore.get(/databases/(default)/documents/consultations/$(caseId)).data.qualitySpecialistId == request.auth.uid ||
        isAdmin()
      );
    }

    match /chat/{caseId}/{fileName} {
      allow read: if isAuthenticated() && isConsultationParticipant(caseId);
      allow write: if isAuthenticated() && isConsultationParticipant(caseId) &&
                   request.resource.size < 15 * 1024 * 1024 && // 15MB limit for audio/video
                   (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('audio/.*') || request.resource.contentType.matches('video/.*'));
    }

    match /reports/{caseId}/{fileName} {
      allow read: if isAuthenticated() && isConsultationParticipant(caseId);
      allow write: if isAuthenticated() && (
        isAdmin() ||
        (firestore.exists(/databases/(default)/documents/consultations/$(caseId)) &&
         firestore.get(/databases/(default)/documents/consultations/$(caseId)).data.consultantId == request.auth.uid)
      ) && request.resource.size < 10 * 1024 * 1024 && request.resource.contentType == 'application/pdf';
    }

    match /meetings/{caseId}/{fileName} {
      allow read: if isAuthenticated() && isConsultationParticipant(caseId);
      allow write: if isAuthenticated() && (
        isAdmin() ||
        (firestore.exists(/databases/(default)/documents/consultations/$(caseId)) &&
         firestore.get(/databases/(default)/documents/consultations/$(caseId)).data.consultantId == request.auth.uid)
      ) && request.resource.size < 250 * 1024 * 1024 && (request.resource.contentType.matches('video/.*') || request.resource.contentType.matches('audio/.*'));
    }
    

    match /calls/{caseId}/{callId}/{fileName} {
      allow read: if isAuthenticated() && isConsultationParticipant(caseId);
      allow write: if isAuthenticated() && isConsultationParticipant(caseId) &&
        request.resource.size < 100 * 1024 * 1024 &&
        (
          request.resource.contentType.matches('audio/.*') ||
          request.resource.contentType == 'video/webm'
        );
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
